AddType image/svg+xml .svg
AddType image/png .png
AddType image/x-icon .ico
AddType text/css .css
AddType application/javascript .js

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # PHP files (e.g. /api/chat.php) — serve directly, do not rewrite
  RewriteRule \.php$ - [L]

  # Static asset bundles (JS/CSS with hashed names)
  RewriteRule ^(assets/.+)$ dist/$1 [L,NC]

  # All other static file types (images, fonts, ico, etc.)
  RewriteRule ^(.+\.(ico|png|jpg|jpeg|webp|gif|svg|woff|woff2|ttf|eot|json|txt|xml|map))$ dist/$1 [L,NC]

  # React SPA — everything else serves dist/index.html
  RewriteRule ^ dist/index.html [L]
</IfModule>
